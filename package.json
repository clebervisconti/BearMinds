{
  "name": "bearminds",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "node --import tsx/esm server/index.ts",
    "seed": "tsx server/scripts/seed.ts",
    "jobs:nightly": "tsx server/jobs/nightly.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@google/genai": "^1.0.0",
    "@hono/node-server": "^1.13.7",
    "@tanstack/react-query": "^5.62.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.0",
    "hono": "^4.6.14",
    "minisearch": "^7.1.0",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "ts-fsrs": "^4.7.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
