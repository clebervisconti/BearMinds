# ============================================================
# BearMinds — configuração (.env.example). COMMIT este arquivo.
# NUNCA comite o .env real (está no .gitignore).
# ============================================================

# ---- LLM providers (commodity, swappable via env) ----
GEMINI_API_KEY=            # mesma chave do opensquad (ver mapa de credenciais)
ANTHROPIC_API_KEY=         # opcional; habilita escalonamento claude-haiku-4-5 (math difícil)

MODEL_DEFAULT=gemini-2.5-flash-lite
MODEL_CONTENT=gemini-2.5-flash
MODEL_MATH_HARD=claude-haiku-4-5

# ---- Segurança / segredos ----
# Gere cada um com: openssl rand -hex 16
PII_ENCRYPTION_KEY=        # AES-256-GCM p/ nome do responsável (32 hex chars = 16 bytes)
SESSION_PEPPER=            # pepper p/ hash de senha / ids de sessão

# ---- Consentimento / LGPD ----
POLICY_VERSION=2026-07-01

# ---- App ----
PORT=8787
NODE_ENV=development
DATABASE_PATH=./data/bearminds.db
# Origem pública do app (usado em links de e-mail / cookies). Ex.: https://bearminds.cybersphere.com.br
PUBLIC_ORIGIN=http://localhost:5173

# ---- E-mail (opcional no P1: verificação + digest de progresso) ----
SMTP_URL=                  # ex.: smtp://user:pass@host:587 (vazio = log no console)
EMAIL_FROM=BearMinds <no-reply@bearminds.cybersphere.com.br>

# ---- Gate de validação por Sign in with Apple (substitui o Cloudflare Access OTP) ----
# GATE_MODE=apple liga o gate; vazio/off desliga (produto público). Ver DEPLOY.md §Apple.
GATE_MODE=                 # apple | off
APPLE_CLIENT_ID=com.cybersphere.bearminds.signin   # Services ID
APPLE_TEAM_ID=Z5H2FL2237
APPLE_KEY_ID=              # Key ID da chave "Sign in with Apple" (.p8) — gerada por Cleber no portal
APPLE_PRIVATE_KEY_PATH=    # ex.: /var/lib/bearminds/apple-signin-key.p8 (0600)
APPLE_REDIRECT_URI=https://bearminds.cybersphere.com.br/api/auth/apple/callback
GATE_ALLOWLIST=cleber.visconti@icloud.com          # e-mails Apple liberados (vírgula)
GATE_COOKIE_SECRET=        # openssl rand -hex 16
